{
  "name": "glc",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "dev": "dotenv-checker && vite --host",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "npx playwright install && playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint src/main/webapp/src/",
    "postinstall": "husky",
    "changelog:generate": "commit-and-tag-version --packageFiles pom.xml --skip.bump --skip.tag --skip.commit -t ''"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.31",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.3",
    "vuetify": "^3.12.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@date-io/date-fns": "^3.2.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@juggle/resize-observer": "^3.4.0",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.58.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28",
    "@types/lodash-es": "^4",
    "@types/node": "^25",
    "@types/xml2js": "^0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "axios": "^1.13.6",
    "commit-and-tag-version": "^12.6.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "dotenv-checker": "^1.1.7",
    "eslint": "^10.0.2",
    "eslint-plugin-format": "^2.0.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.1",
    "lodash-es": "^4.17.23",
    "npm-run-all2": "^8.0.4",
    "sass": "^1.97.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5",
    "vue3-toastify": "^0.2.8",
    "xml2js": "^0.6.2"
  }
}
