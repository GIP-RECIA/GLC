{
  "name": "glc",
  "type": "module",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "dev": "dotenv-checker && vite --host",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "npx playwright install && playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint src/main/webapp/src/",
    "postinstall": "husky",
    "changelog:generate": "commit-and-tag-version --packageFiles pom.xml --skip.bump --skip.tag --skip.commit -t ''"
  },
  "dependencies": {
    "@pinia/colada": "^1.2.1",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.16.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.33",
    "vue-i18n": "^11.4.0",
    "vue-router": "^5.0.6",
    "vuetify": "^3.12.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@date-io/date-fns": "^3.2.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.2.0",
    "@gip-recia/ui": "^1.0.4",
    "@gip-recia/ui-webcomponents": "^1.13.0",
    "@intlify/unplugin-vue-i18n": "^11.1.2",
    "@juggle/resize-observer": "^3.4.0",
    "@pinia/colada-devtools": "^0.4.5",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.59.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28",
    "@types/lodash-es": "^4",
    "@types/node": "^24",
    "@types/xml2js": "^0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "commit-and-tag-version": "^12.7.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "dotenv-checker": "^1.1.7",
    "eslint": "^10.3.0",
    "eslint-plugin-format": "^2.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "lodash-es": "^4.18.1",
    "npm-run-all2": "^8.0.4",
    "ress": "^5.0.2",
    "sass": "^1.99.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.5",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8",
    "vue3-toastify": "^0.2.9",
    "xml2js": "^0.6.2"
  }
}
